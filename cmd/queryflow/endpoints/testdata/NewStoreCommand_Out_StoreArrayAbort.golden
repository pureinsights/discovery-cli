{"active":true,"creationTimestamp":"2025-08-14T18:02:11Z","id":"9ababe08-0b74-4672-bb7c-e7a8227d6d4c","labels":[],"lastUpdatedTimestamp":"2025-08-14T18:02:11Z","name":"MongoDB endpoint","secret":"mongo-secret","type":"mongo"}
Usage:
  store [<files>...] [flags]

Examples:
	# Store an endpoint with the JSON configuration in a file
	discovery queryflow endpoint store endpointjsonfile.json

	# Store an endpoint with the JSON configuration in the data flag
	discovery queryflow endpoint store --data '{"type":"default","uri":"/my/endpoint","httpMethod":"GET","name":"my-endpoint","pipeline":"782bfece-20a2-4382-bacb-1c9c550e2d58","timeout":"60s"}'

Flags:
      --abort-on-error   aborts the operation if there is an error
  -d, --data string      the JSON with the configurations that will be upserted
  -h, --help             help for store
  -p, --profile string   configuration profile to use (default "default")

